---
http:
  routers:
    to-radarr-http:
      rule: "Host(`movies.{{ external_domain }}`)"
      service: radarr
      middlewares:
        - https-redirect

    to-radarr:
      rule: "Host(`movies.{{ external_domain }}`)"
      service: radarr
      tls:
        certResolver: letsencrypt
        domains:
          - main: "{{ external_domain }}"
            sans:
              - "*.{{ external_domain }}"

  services:
    radarr:
      loadBalancer:
        servers:
          - url: http://{{ tf_radarr_ip }}:7878

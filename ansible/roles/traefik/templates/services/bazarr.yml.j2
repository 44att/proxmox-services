---
http:
  routers:
    to-bazarr-http:
      rule: "Host(`subtitles.{{ external_domain }}`)"
      service: bazarr
      middlewares:
        - https-redirect

    to-bazarr:
      rule: "Host(`subtitles.{{ external_domain }}`)"
      service: bazarr
      tls:
        certResolver: letsencrypt
        domains:
          - main: "{{ external_domain }}"
            sans:
              - "*.{{ external_domain }}"

  services:
    bazarr:
      loadBalancer:
        servers:
          - url: http://{{ tf_bazarr_ip }}:6767

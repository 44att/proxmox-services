---
http:
  routers:
    to-prowlarr-http:
      rule: "Host(`search.{{ external_domain }}`)"
      service: prowlarr
      middlewares:
        - https-redirect

    to-prowlarr:
      rule: "Host(`search.{{ external_domain }}`)"
      service: prowlarr
      tls:
        certResolver: letsencrypt
        domains:
          - main: "{{ external_domain }}"
            sans:
              - "*.{{ external_domain }}"

  services:
    prowlarr:
      loadBalancer:
        servers:
          - url: http://{{ tf_prowlarr_ip }}:9696
